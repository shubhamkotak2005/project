<%- include("../partials/header", { pageTitle }) %>

<section class="hero">
  <h1>Canteens</h1>
  <p class="muted">Choose a spot and browse the menu.</p>
</section>

<% if (!shops.length) { %>
  <div class="card">
    <p>No canteens are listed yet. Run <code class="code">npm run seed</code> for sample data.</p>
  </div>
<% } else { %>
  <div class="grid grid--shops">
    <% shops.forEach((s) => { %>
      <a class="card card--link" href="/shops/<%= s.slug %>">
        <h2 class="card__title"><%= s.name %></h2>
        <% if (s.description) { %>
          <p class="muted card__desc"><%= s.description %></p>
        <% } %>
        <span class="btn btn--small">View menu</span>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include("../partials/footer") %>

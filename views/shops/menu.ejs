<%- include("../partials/header", { pageTitle }) %>

<div class="breadcrumb">
  <a href="/shops">Canteens</a>
  <span class="muted"> / </span>
  <span><%= shop.name %></span>
</div>

<section class="hero hero--compact">
  <h1><%= shop.name %></h1>
  <% if (shop.description) { %>
    <p class="muted"><%= shop.description %></p>
  <% } %>
</section>

<% if (!menuItems.length) { %>
  <div class="card"><p class="muted">No menu items yet.</p></div>
<% } else { %>
  <ul class="menu-list">
    <% menuItems.forEach((item) => { %>
      <li class="menu-list__row card">
        <div class="menu-list__info">
          <h3 class="menu-list__name"><%= item.name %></h3>
          <% if (item.description) { %>
            <p class="muted menu-list__desc"><%= item.description %></p>
          <% } %>
          <p class="menu-list__price">₹<%= item.price.toFixed(2) %></p>
          <% if (!item.available) { %>
            <p class="tag tag--muted">Unavailable</p>
          <% } %>
        </div>
        <% if (currentUser && currentUser.role === "student" && item.available) { %>
          <form method="post" action="/cart/add" class="menu-list__form">
            <input type="hidden" name="menuItemId" value="<%= item._id %>" />
            <input type="hidden" name="redirect" value="/shops/<%= shop.slug %>" />
            <label class="sr-only"><span>Quantity</span>
              <input class="input--qty" name="quantity" type="number" min="1" max="99" value="1" />
            </label>
            <button class="btn btn--small" type="submit">Add</button>
          </form>
        <% } else if (!currentUser && item.available) { %>
          <a class="btn btn--ghost btn--small" href="/login">Log in to order</a>
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include("../partials/footer") %>

<%- include("partials/header", { pageTitle }) %>

<section class="hero">
  <h1>Skip the queue.</h1>
  <p>Pre-order from campus canteens, pay (mock), get an OTP, and collect fast.</p>

  <% if (!currentUser) { %>
    <div class="row">
      <a class="btn" href="/shops">Browse canteens</a>
      <a class="btn" href="/signup">Create account</a>
      <a class="btn btn--ghost" href="/login">Log in</a>
    </div>
  <% } else { %>
    <div class="card">
      <p>You’re logged in as <strong><%= currentUser.role %></strong>.</p>
      <% if (currentUser.role === "student") { %>
        <p class="muted">Browse canteens, add items to your cart, and place an order to get a pickup code.</p>
        <div class="row">
          <a class="btn" href="/shops">Browse canteens</a>
          <a class="btn btn--ghost" href="/orders">My orders</a>
        </div>
      <% } else if (currentUser.role === "vendor") { %>
        <p class="muted">Pending orders → mark ready → verify pickup code → completed.</p>
        <div class="row">
          <a class="btn" href="/vendor/orders/pending">Pending orders</a>
          <a class="btn btn--ghost" href="/vendor/menu">Manage menu</a>
          <a class="btn btn--ghost" href="/vendor/verify">Verify pickup</a>
          <a class="btn btn--ghost" href="/vendor/orders/completed">Completed</a>
        </div>
      <% } %>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>


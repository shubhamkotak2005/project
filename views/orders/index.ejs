<%- include("../partials/header", { pageTitle }) %>

<section class="hero hero--compact">
  <h1>My orders</h1>
</section>

<% if (!orders.length) { %>
  <div class="card"><p class="muted">No orders yet.</p></div>
<% } else { %>
  <ul class="order-list">
    <% orders.forEach((o) => { %>
      <li class="card order-list__item">
        <div class="order-list__meta">
          <a href="/orders/<%= o._id %>">Order …<%= String(o._id).slice(-6) %></a>
          <span class="tag tag--<%= o.status === "completed" ? "ok" : o.status === "paid" ? "pending" : "muted" %>"><%= o.status %></span>
        </div>
        <p class="muted small"><%= o.shop?.name || "Canteen" %> · ₹<%= o.total.toFixed(2) %> · <%= new Date(o.createdAt).toLocaleString() %></p>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include("../partials/footer") %>

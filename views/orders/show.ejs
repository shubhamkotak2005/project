<%- include("../partials/header", { pageTitle }) %>

<div class="breadcrumb">
  <a href="/orders">My orders</a>
  <span class="muted"> / </span>
  <span>…<%= String(order._id).slice(-6) %></span>
</div>

<% const studentLabel = order.status === "pending_payment" ? "Payment pending" : order.status === "paid" ? "Paid — waiting for canteen" : order.status === "ready_for_pickup" ? "Ready for pickup" : order.status === "completed" ? "Completed" : order.status; %>
<% const tagClass = order.status === "completed" ? "ok" : order.status === "ready_for_pickup" ? "pending" : order.status === "paid" ? "pending" : "muted"; %>

<div class="card order-detail">
  <div class="order-detail__head">
    <h1>Order details</h1>
    <span class="tag tag--<%= tagClass %>"><%= studentLabel %></span>
  </div>
  <p class="muted"><%= order.shop?.name || "Canteen" %> · <%= new Date(order.createdAt).toLocaleString() %></p>

  <% if (order.status === "paid") { %>
    <p class="muted">The canteen is preparing your order. When they mark it ready, your pickup code will appear here.</p>
  <% } else if (order.status === "ready_for_pickup") { %>
    <div class="otp-box">
      <p class="otp-box__label">Pickup code</p>
      <p class="otp-box__code"><%= order.pickupOtp %></p>
      <p class="muted small">Show this code at the counter. The vendor enters it in <strong>Verify pickup</strong> when you collect.</p>
    </div>
  <% } else if (order.status === "completed") { %>
    <p class="muted">This order was picked up. (Code used: <strong class="mono"><%= order.pickupOtp %></strong>.)</p>
  <% } else if (order.status === "pending_payment") { %>
    <p class="muted">Complete payment when checkout supports it.</p>
  <% } %>

  <h2 class="h2">Items</h2>
  <ul class="plain-list">
    <% order.items.forEach((line) => { %>
      <li><%= line.quantity %> × <%= line.name %> — ₹<%= (line.price * line.quantity).toFixed(2) %></li>
    <% }) %>
  </ul>
  <p class="cart-total"><strong>Total:</strong> ₹<%= order.total.toFixed(2) %></p>
</div>

<script>
  (function () {
    var orderId = "<%= order._id %>";
    var currentStatus = "<%= order.status %>";

    var intervalId = setInterval(async function () {
      try {
        var res = await fetch("/api/orders/" + encodeURIComponent(orderId) + "/status", {
          headers: { Accept: "application/json" },
          credentials: "same-origin",
        });
        if (!res.ok) return;

        var data = await res.json();
        if (data.status && data.status !== currentStatus) {
          window.location.reload();
        }
      } catch (e) {
        // Keep polling; a temporary network hiccup should not break the page.
      }
    }, 5000);

    window.addEventListener("beforeunload", function () {
      clearInterval(intervalId);
    });
  })();
</script>

<%- include("../partials/footer") %>

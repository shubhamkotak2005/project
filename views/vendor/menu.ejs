<%- include("../partials/header", { pageTitle }) %>

<section class="hero hero--compact">
  <h1>Manage menu</h1>
  <p class="muted">Create items, edit details, and toggle availability for students browsing your canteen.</p>
</section>

<div class="card">
  <div class="row row--split">
    <span class="tag <%= shop.isOpen ? "tag--ok" : "tag--warn" %>">
      <%= shop.isOpen ? "Shop Open" : "Shop Closed" %>
    </span>
    <form method="post" action="/vendor/shop/toggle">
      <button class="btn" type="submit">
        <%= shop.isOpen ? "Close Shop" : "Open Shop" %>
      </button>
    </form>
  </div>
</div>

<div class="card">
  <h2 class="h2">Add new item</h2>
  <form method="post" action="/vendor/menu" class="form">
    <label>
      <span>Name</span>
      <input name="name" type="text" maxlength="80" required />
    </label>
    <label>
      <span>Description (optional)</span>
      <input name="description" type="text" maxlength="160" />
    </label>
    <label>
      <span>Price (₹)</span>
      <input name="price" type="number" min="1" step="0.01" required />
    </label>
    <button class="btn" type="submit">Create item</button>
  </form>
</div>

<% if (!menuItems.length) { %>
  <div class="card"><p class="muted">No menu items yet.</p></div>
<% } else { %>
  <div class="card" style="overflow-x: auto;">
    <table class="table vendor-menu-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Availability</th>
          <th style="width: 1%; white-space: nowrap;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% menuItems.forEach((item) => { %>
          <tr data-item-row data-item-id="<%= item._id %>">
            <td>
              <div class="grid" style="gap: 8px;">
                <label>
                  <span class="sr-only">Name</span>
                  <input data-edit-name type="text" value="<%= item.name %>" required />
                </label>
                <label>
                  <span class="sr-only">Description</span>
                  <input data-edit-description type="text" value="<%= item.description || "" %>" placeholder="Description (optional)" />
                </label>
                <label>
                  <span class="sr-only">Price</span>
                  <input data-edit-price type="number" min="1" step="0.01" value="<%= Number(item.price).toFixed(2) %>" required />
                </label>
              </div>
            </td>
            <td>
              <span class="tag vendor-menu-table__badge <%= item.available ? "tag--ok" : "tag--muted" %>" data-availability-badge>
                <%= item.available ? "Available" : "Unavailable" %>
              </span>
            </td>
            <td>
              <div class="row" style="gap: 8px;">
                <button
                  type="button"
                  class="btn btn--small"
                  data-save-item
                  data-item-id="<%= item._id %>"
                >
                  Save
                </button>
                <button
                  type="button"
                  class="btn btn--small btn--ghost"
                  data-toggle-availability
                  data-item-id="<%= item._id %>"
                >
                  <%= item.available ? "Mark unavailable" : "Mark available" %>
                </button>
                <button
                  type="button"
                  class="btn btn--small btn--ghost"
                  data-delete-item
                  data-item-id="<%= item._id %>"
                >
                  Delete
                </button>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<script>
(function () {
  function setBusy(btn, busy) {
    btn.disabled = !!busy;
    if (busy) btn.setAttribute("aria-busy", "true");
    else btn.removeAttribute("aria-busy");
  }

  async function jsonFetch(url, opts) {
    var res = await fetch(url, Object.assign({ credentials: "same-origin" }, opts || {}));
    var body = await res.json().catch(function () { return {}; });
    if (!res.ok) {
      var msg = body && body.error ? body.error : "Request failed.";
      var err = new Error(msg);
      err.status = res.status;
      throw err;
    }
    return body;
  }

  document.querySelectorAll("[data-toggle-availability]").forEach(function (btn) {
    btn.addEventListener("click", async function () {
      var id = btn.getAttribute("data-item-id");
      if (!id || btn.disabled) return;
      setBusy(btn, true);
      try {
        var body = await jsonFetch("/menu/" + encodeURIComponent(id) + "/toggle", {
          method: "PATCH",
          headers: { Accept: "application/json" },
        });
        var item = body.item;
        var row = btn.closest("[data-item-row]");
        var badge = row && row.querySelector("[data-availability-badge]");
        if (badge && item) {
          badge.textContent = item.available ? "Available" : "Unavailable";
          badge.classList.toggle("tag--ok", item.available);
          badge.classList.toggle("tag--muted", !item.available);
        }
        if (item) {
          btn.textContent = item.available ? "Mark unavailable" : "Mark available";
        }
      } catch (e) {
        alert(e.message || "Could not update item.");
      } finally {
        setBusy(btn, false);
      }
    });
  });

  document.querySelectorAll("[data-save-item]").forEach(function (btn) {
    btn.addEventListener("click", async function () {
      var id = btn.getAttribute("data-item-id");
      var row = btn.closest("[data-item-row]");
      if (!id || !row || btn.disabled) return;

      var nameEl = row.querySelector("[data-edit-name]");
      var descEl = row.querySelector("[data-edit-description]");
      var priceEl = row.querySelector("[data-edit-price]");

      var payload = {
        name: (nameEl && nameEl.value ? String(nameEl.value) : "").trim(),
        description: (descEl && descEl.value ? String(descEl.value) : "").trim(),
        price: priceEl && priceEl.value ? Number(priceEl.value) : 0,
      };

      setBusy(btn, true);
      try {
        await jsonFetch("/vendor/menu/" + encodeURIComponent(id), {
          method: "PATCH",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify(payload),
        });
      } catch (e) {
        alert(e.message || "Could not save item.");
      } finally {
        setBusy(btn, false);
      }
    });
  });

  document.querySelectorAll("[data-delete-item]").forEach(function (btn) {
    btn.addEventListener("click", async function () {
      var id = btn.getAttribute("data-item-id");
      var row = btn.closest("[data-item-row]");
      if (!id || !row || btn.disabled) return;
      if (!confirm("Delete this menu item?")) return;

      setBusy(btn, true);
      try {
        await jsonFetch("/vendor/menu/" + encodeURIComponent(id), {
          method: "DELETE",
          headers: { Accept: "application/json" },
        });
        row.remove();
      } catch (e) {
        alert(e.message || "Could not delete item.");
      } finally {
        setBusy(btn, false);
      }
    });
  });
})();
</script>

<%- include("../partials/footer") %>

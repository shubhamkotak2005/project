<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle ? `${pageTitle} • Smart Canteen` : "Smart Canteen" %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="container topbar__inner">
        <div class="topbar__brand-row">
          <a class="brand" href="/">Smart Canteen</a>
          <button
            type="button"
            class="nav-toggle"
            data-nav-toggle
            aria-expanded="false"
            aria-controls="main-nav"
            aria-label="Open menu"
          >
            ☰
          </button>
        </div>
        <nav id="main-nav" class="nav nav-main" aria-label="Main">
          <a class="nav__link" href="/shops">Canteens</a>
          <% if (currentUser && currentUser.role === "student") { %>
            <a class="nav__link" href="/cart">Cart<% if (typeof cartCount === "number" && cartCount > 0) { %> (<%= cartCount %>)<% } %></a>
            <a class="nav__link" href="/orders">Orders</a>
          <% } %>
          <% if (currentUser && currentUser.role === "vendor") { %>
            <%- include("./vendor-nav") %>
          <% } %>
          <% if (currentUser) { %>
            <span class="nav__text nav-main__greet">Hi, <%= currentUser.name %></span>
            <form method="post" action="/logout" class="inline nav-main__logout">
              <button class="btn btn--ghost nav-main__logout-btn" type="submit">Logout</button>
            </form>
          <% } else { %>
            <a class="btn btn--ghost nav-main__auth" href="/login">Login</a>
            <a class="btn nav-main__auth" href="/signup">Sign up</a>
          <% } %>
        </nav>
      </div>
    </header>

    <main class="container">
      <% if (flash?.success?.length) { %>
        <div class="flash flash--success"><%= flash.success[0] %></div>
      <% } %>
      <% if (flash?.error?.length) { %>
        <div class="flash flash--error"><%= flash.error[0] %></div>
      <% } %>


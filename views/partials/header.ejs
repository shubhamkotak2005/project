<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle ? `${pageTitle} • Smart Canteen` : "Smart Canteen" %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="container topbar__inner">
        <a class="brand" href="/">Smart Canteen</a>
        <nav class="nav">
          <a class="nav__link" href="/shops">Canteens</a>
          <% if (currentUser && currentUser.role === "student") { %>
            <a class="nav__link" href="/cart">Cart<% if (typeof cartCount === "number" && cartCount > 0) { %> (<%= cartCount %>)<% } %></a>
            <a class="nav__link" href="/orders">Orders</a>
          <% } %>
          <% if (currentUser && currentUser.role === "vendor") { %>
            <a class="nav__link" href="/vendor/verify">Verify pickup</a>
          <% } %>
          <% if (currentUser) { %>
            <span class="nav__text">Hi, <%= currentUser.name %></span>
            <form method="post" action="/logout" class="inline">
              <button class="btn btn--ghost" type="submit">Logout</button>
            </form>
          <% } else { %>
            <a class="btn btn--ghost" href="/login">Login</a>
            <a class="btn" href="/signup">Sign up</a>
          <% } %>
        </nav>
      </div>
    </header>

    <main class="container">
      <% if (flash?.success?.length) { %>
        <div class="flash flash--success"><%= flash.success[0] %></div>
      <% } %>
      <% if (flash?.error?.length) { %>
        <div class="flash flash--error"><%= flash.error[0] %></div>
      <% } %>

